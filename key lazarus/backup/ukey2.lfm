  object upCLIENTE: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM KEY'
      'WHERE'
      '  ((KEY.ID IS NULL AND :OLD_ID IS NULL) OR (KEY.ID = :OLD_ID))'
    )
    InsertSQL.Strings = (
      'INSERT INTO KEY'
      '  (ID, USUARIO, SENHA, DESCRICAO)'
      'VALUES'
      '  (:ID, :USUARIO, :SENHA, :DESCRICAO)'
    )
    ModifySQL.Strings = (
      'UPDATE KEY SET'
      '  ID = :ID,'
      '  USUARIO = :USUARIO,'
      '  SENHA = :SENHA,'
      '  DESCRICAO = :DESCRICAO'
      'WHERE'
      '  ((KEY.ID IS NULL AND :OLD_ID IS NULL) OR (KEY.ID = :OLD_ID))'
    )
    UseSequenceFieldForRefreshSQL = False
    Left = 112
    Top = 152
    ParamData = <    
